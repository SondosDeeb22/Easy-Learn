# -----------------------------------------------------------
# Build context: webApp/ directory
#   docker build -f frontend/Dockerfile .
# -----------------------------------------------------------

FROM node:22.19.0
WORKDIR /app/frontend

# -----------------------------------------------------------

COPY package.json ./

RUN npm install

# -----------------------------------------------------------

# install versions in package-lock.json
RUN npm ci

COPY . .

# -----------------------------------------------------------

EXPOSE 5173
# -----------------------------------------------------------

CMD ["npm", "run", "dev", "--", "--host", "0.0.0.0"]
