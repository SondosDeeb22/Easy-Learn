    "/users/students": {
      "get": {
        "description": "Fetch a list of students with pagination. Filter by courseId, or semesterId.",
        "operationId": "UsersController_getStudents",
        "parameters": [
          {
            "name": "studentId",
            "required": false,
            "in": "query",
            "description": "Filter by Student ID",
            "schema": {
              "example": "20261144",
              "type": "string"
            }
          },
          {
            "name": "courseId",
            "required": false,
            "in": "query",
            "description": "Filter by Course ID",
            "schema": {
              "example": "50000004",
              "type": "string"
            }
          },
          {
            "name": "semesterId",
            "required": false,
            "in": "query",
            "description": "Filter by Semester ID",
            "schema": {
              "example": "20000008",
              "type": "string"
            }
          },
          {
            "name": "status",
            "required": false,
            "in": "query",
            "description": "Filter by Student Status",
            "schema": {
              "example": "active",
              "type": "string",
              "enum": [
                "active",
                "passive",
                "suspended",
                "graduated"
              ]
            }
          },
          {
            "name": "page",
            "required": true,
            "in": "query",
            "description": "The page number for pagination context",
            "schema": {
              "example": 1,
              "type": "number"
            }
          },
          {
            "name": "limit",
            "required": true,
            "in": "query",
            "description": "Number of rows to return per page",
            "schema": {
              "example": 10,
              "type": "number"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "User fetched successfully"
          },
          "403": {
            "description": "Forbidden access"
          }
        },
        "summary": "Get List of Filtered Students",
        "tags": [
          "users"
        ]
      }
    },
