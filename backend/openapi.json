            "example": "PHY101"
          },
          "title": {
            "type": "string",
            "description": "Course Title",
            "example": "Introduction to Physics"
          },
          "credit": {
            "type": "number",
            "description": "Course Credits",
            "example": 3
          },
          "active": {
            "type": "boolean",
            "description": "Status (active)",
            "example": true
          }
        },
        "required": [
          "code",
          "title",
          "credit"
        ]
      },
      "UpdateCourseDto": {
        "type": "object",
        "properties": {
          "id": {
            "type": "string",
            "description": "The unique course identifier",
            "example": "50000004"
          },
          "code": {
            "type": "string",
            "description": "Course Code",
            "example": "PHY101"
          },
          "title": {
            "type": "string",
            "description": "Course Title",
            "example": "Introduction to Physics"
          },
          "credit": {
            "type": "number",
            "description": "Course Credits",
            "example": 3
          },
          "active": {
            "type": "boolean",
            "description": "Status (active)",
            "example": true
          }
        },
        "required": [
          "id",
          "code",
          "title",
          "credit",
          "active"
        ]
      },
      "LoginCredDto": {
        "type": "object",
        "properties": {
          "id": {
            "type": "string",
